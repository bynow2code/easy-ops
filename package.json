{
  "name": "easyops",
  "version": "1.0.0",
  "description": "EasyOps - Script Manager Desktop App",
  "main": "electron/main.js",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js",
    "build": "cd frontend && npm run build",
    "electron-dev": "npm run build && electron .",
    "electron-build": "npm run build && electron-builder --win --x64",
    "electron-build-dir": "if exist dist-electron rmdir /s /q dist-electron && npm run build && electron-builder --dir --win"
  },
  "keywords": [
    "electron",
    "script-manager",
    "easyops"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^23.3.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.easyops.app",
    "productName": "EasyOps",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!package-lock.json",
          "!package.json"
        ]
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "frontend/public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
