{
  "name": "easyops",
  "version": "1.0.0",
  "description": "EasyOps - Script Manager Desktop App",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "electron-dev": "npm run build && electron .",
    "electron-build": "npm run build && electron-builder --win --x64",
    "electron-build-dir": "npm run build && electron-builder --dir --win",
    "start": "electron ."
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^23.3.2"
  },
  "build": {
    "appId": "com.easyops.app",
    "productName": "EasyOps",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!package-lock.json",
          "!package.json"
        ]
      },
      {
        "from": "client/dist",
        "to": "client/dist"
      }
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "client/public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
