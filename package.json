{
  "name": "easyops",
  "version": "1.0.0",
  "description": "EasyOps - Script Manager Desktop App",
  "main": "electron/main.js",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js",
    "build": "cd frontend && npm run build",
    "electron-dev": "npm run build && electron .",
    "electron-build": "npm run build && electron-builder --win --x64",
    "electron-build-dir": "if exist dist-electron rmdir /s /q dist-electron && npm run build && electron-builder --dir --win"
  },
  "keywords": ["electron", "script-manager", "easyops"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^23.3.2",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.easyops.app",
    "productName": "EasyOps",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json",
      "!frontend/src/**/*",
      "!frontend/node_modules/**/*",
      "!backend/node_modules/**/*",
      "!dist-electron/**/*",
      "!**/*.md",
      "!**/.gitignore",
      "!frontend/eslint.config.js",
      "!frontend/vite.config.js",
      "!frontend/index.html",
      "!frontend/package-lock.json",
      "!frontend/package.json",
      "!backend/package-lock.json",
      "!backend/package.json",
      "!start.js",
      "!node_modules/**/*"
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
